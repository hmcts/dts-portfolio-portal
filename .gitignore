# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Editors / IDEs ---
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo
*~
.history/

# --- Secrets / env ---
# Never commit local env or credentials. See CLAUDE.md (global) for secrets handling.
.env
.env.*
!.env.example
.envrc
*.pem
*.key
*.p12
*.pfx
secrets.*

# --- Claude Code local state ---
.claude/settings.local.json
.claude/.credentials.json
.claude/memory/

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Node / JS (in case Phase 0 picks a JS stack) ---
node_modules/
.pnp.*
.yarn/cache
.yarn/install-state.gz
.yarn/build-state.yml
.yarn/unplugged

# --- TypeScript ---
*.tsbuildinfo

# next-env.d.ts is generated + rewritten by Next.js (dev vs build
# rewrites the routes.d.ts import path). create-next-app's default
# .gitignore excludes it; we generate a stub at install time via
# postinstall so tsc still has the file to parse.
next-env.d.ts

# --- Build / dist (generic) ---
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.astro/
.vercel/
.netlify/
.turbo/
.cache/
.parcel-cache/

# --- Test / coverage ---
coverage/
.nyc_output/

# --- Playwright ---
test-results/
playwright-report/
playwright/.cache/

# --- Python (in case Phase 0 picks Python) ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Prototype render output (regenerable; not committed) ---
docs/prototype/rendered.html
docs/prototype/rendered.png
docs/prototype/computed-tokens.json

# --- Python (backend/)
# Scoped to backend/ so these patterns are unambiguous in the monorepo.
# The generic __pycache__ / .venv patterns above still catch anything outside
# backend/ if a one-off script ever lives at the root.
backend/__pycache__/
backend/**/__pycache__/
backend/.pytest_cache/
backend/.ruff_cache/
backend/.mypy_cache/
backend/.venv/
backend/htmlcov/
backend/.coverage
backend/coverage.xml

# --- Generated TypeScript client (do not commit; regenerated each CI run)
frontend/lib/api/generated/

# --- Local scratch ---
tmp/
temp/
scratch/
