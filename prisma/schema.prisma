// Prisma schema for the DTS Portfolio Portal.
//
// Entity model from requirements spec §4:
//   Jurisdiction (1) ─ Product Domain (N) ─┬─ Team (N)
//                                          └─ Product (N) ─ Initiative (chip)
//
// Audit log from requirements spec §7.6: append-only record of every
// content upload. Append-only is enforced at the database layer in
// migrations (REVOKE UPDATE, DELETE on the submission table), not here.
//
// Identity rules:
//   - Each entity has a stable cuid() primary key plus a unique URL slug
//     (the slug is what /j/<slug>, /d/<slug>, /t/<slug>, /p/<slug> use).
//   - Slugs are author-set in markdown front-matter; the AI parser
//     validates uniqueness at approve time, not at upload time.
//   - Jurisdiction slugs are a fixed taxonomy in v1 (§3.2): crime, civil,
//     family, tribunals, administrative.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntityKind {
  jurisdiction
  domain
  team
  product
}

enum TimeBucket {
  NOW
  NEXT
  LATER
}

enum ProductStage {
  discovery
  alpha
  beta
  live
  retiring
  retired
}

model Jurisdiction {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  domains     ProductDomain[]
  consumes    Product[]      @relation("ConsumedByJurisdiction")
}

model ProductDomain {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  description     String?
  strategicThemes Theme[]
  jurisdictionId  String
  jurisdiction    Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  teams           Team[]
  products        Product[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([jurisdictionId])
}

model Theme {
  id          String        @id @default(cuid())
  title       String
  description String?
  domainId    String
  domain      ProductDomain @relation(fields: [domainId], references: [id])
  position    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([domainId])
}

model Team {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  description   String?
  contact       String?
  domainId      String
  domain        ProductDomain @relation(fields: [domainId], references: [id])
  operates      Product[]     @relation("TeamOperatesProduct")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([domainId])
}

model Product {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String?
  stage           ProductStage   @default(discovery)
  domainId        String
  domain          ProductDomain  @relation(fields: [domainId], references: [id])
  operatingTeamId String
  operatingTeam   Team           @relation("TeamOperatesProduct", fields: [operatingTeamId], references: [id])
  consumedBy      Jurisdiction[] @relation("ConsumedByJurisdiction")
  initiatives    Initiative[]
  outboundLinks  OutboundLink[]
  lastApprovedAt DateTime?
  lastApprovedBy String?
  versionNumber  Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([domainId])
  @@index([operatingTeamId])
}

model Initiative {
  id          String     @id @default(cuid())
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  bucket      TimeBucket
  title       String
  description String?
  outboundUrl String?
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([productId, bucket])
}

model OutboundLink {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  label     String
  url       String
  position  Int      @default(0)

  @@index([productId])
}

// Per-parse metric record per Phase 2 task 2.13. One row written for
// every AI parser invocation (Azure OpenAI or the strict-template
// fallback), recording token usage, latency and outcome so the ops
// cost dashboard can aggregate spend by day and flag budget breaches.
//
// Append-only: there is no scenario where an emitted metric should be
// edited; the same DB-layer trigger applied to Submission also guards
// this table (see migration).
model AiParseMetric {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  // The parser source — matches AiParseSource in src/lib/ai-parser/types.ts.
  source            String
  // The Azure deployment name when source = "azure-openai"; null otherwise.
  model             String?
  // "success" or "failure" — failures still record token usage because
  // we get charged for partial completions and rate-limit errors.
  outcome           String
  // Token counts populated by Azure OpenAI from `response.usage`.
  // Null for the strict-template path (no model call) and for failures
  // where the model didn't reply at all.
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  // Wall-clock latency of the parse() call in milliseconds.
  latencyMs         Int
  // For failures: the AiParseFailure.reason string. Helps triage why
  // a parse failed without joining back to Submission.
  failureReason     String?
  // Optional link to the audit-log row this parse belongs to. Null if
  // the parse was speculative (e.g. a future "try-parse before
  // upload" UX). Not a FK on purpose — submissions are append-only
  // but a metric can outlive the submission it produced.
  submissionId      String?

  @@index([createdAt])
  @@index([source, outcome])
}

// Search event log per Phase 3 task 3.7. One row per /api/search hit
// (recorded server-side) and one row per result click (recorded
// client-side via a beacon). The dashboard at /ops/search reads this
// to surface zero-result queries and queries-without-clicks for
// relevance triage.
//
// Append-only at the DB layer (same trigger pattern as Submission +
// AiParseMetric). User identity is the Phase 4 auth subject hash; we
// never store the email itself here per spec §8.4 data minimisation.
model SearchEvent {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  // "query" when the user submits a search; "click" when they open a result.
  kind         String
  query        String
  // For "query" events: how many results came back.
  resultCount  Int?
  // For "click" events: which entity the user clicked.
  clickedEntityType String?
  clickedEntityId   String?
  clickedPosition   Int?
  // Anonymous-by-default subject identifier (SHA-256 of the auth
  // sub claim). Null until Phase 4 auth wires real identities; the
  // recorder accepts null so we don't lose pre-auth queries.
  subjectHash  String?

  @@index([createdAt])
  @@index([kind, createdAt])
  @@index([query])
}

// Append-only audit log. INSERT-only at the application layer; UPDATE
// and DELETE revoked at the database layer in migrations. Tracks every
// markdown upload + AI parse + approval event per spec §7.6.
model Submission {
  id                String      @id @default(cuid())
  entityKind        EntityKind
  entityId          String?
  submitter         String
  submittedAt       DateTime    @default(now())
  sourceMarkdown    Bytes
  sourceMarkdownSha String
  aiParsedOutput    Json?
  aiConfidenceFlags Json?
  // Records which parser produced `aiParsedOutput`. Surfaces on the
  // approval screen so reviewers know whether they're reading AOAI
  // output or the strict-template fallback (spec §7.5; Phase 2 task
  // 2.14). Nullable for back-compat with rows persisted before the
  // column was added.
  aiParseSource     String?
  approver          String?
  approvedAt        DateTime?
  versionNumber     Int?
  notes             String?

  @@index([entityKind, entityId])
  @@index([sourceMarkdownSha])
}
