# Copy to `.env.local` (never commit `.env.local`) for local development.
# Production values come from Azure Key Vault via App Service managed
# identity — see ADR-008.

# Postgres connection string used by Prisma. The docker-compose stack
# starts a local Postgres on 5432 with these credentials.
DATABASE_URL="postgresql://portal:portal@localhost:5432/portal?schema=public"

# Local-dev auth shim — see ADR-005. Mimics what Easy Auth would inject
# into `X-MS-CLIENT-PRINCIPAL`. Never set in production; the production
# build asserts NODE_ENV === 'production' and refuses to honour these.
DEV_FAKE_PRINCIPAL_EMAIL="dev.user@justice.gov.uk"
DEV_FAKE_PRINCIPAL_NAME="Dev User"
DEV_FAKE_PRINCIPAL_GROUPS="team-court-hearing-domain-a"

# Ops kill-switch for Azure OpenAI: when set to "true" or "1", the
# parser factory ignores AOAI env and returns the strict-template
# fallback. See docs/runbooks/bootstrap-infra-repo.md ("Operating
# without Azure OpenAI") and spec §7.5. Leave unset (or "false") for
# normal operation.
# AI_PARSER_FORCE_FALLBACK="false"
